  "keyFeatures": [
    "JavaScript execution on the Erlang BEAM VM",
    "Actor-based concurrency with Arc.spawn, Arc.send, and Arc.receive",
    "ES2023+ parser with module system support",
    "Bytecode compiler with three-phase pipeline",
    "REPL with interactive JavaScript evaluation",
    "ECMAScript Test262 conformance testing"
  ],
  "publicApiSurface": [
    "Arc.spawn(fn)",
    "Arc.send(pid, message)",
    "Arc.receive(timeout?)",
    "Arc.self()",
    "Arc.log(...args)",
    "Arc.sleep(ms)",
    "parser.parse(source, mode)",
    "compiler.compile(program)",
    "module.compile_bundle(entry, source, resolver)",
    "module.evaluate_bundle(bundle, heap, builtins, global)",
    "vm.run_and_drain(template, heap, builtins, global)"
  ]
}
